# Supabase (obrigatório para login e inventários)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Para migrações automáticas (opcional):
# Opção 1: Personal Access Token em https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxx
# Opção 2: Connection string em Project Settings > Database
# DATABASE_URL=postgresql://postgres.[ref]:[SENHA]@...
