# Supabase (obrigatório para inventários; login usa auth-hashes ou Supabase users)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Login em produção (Vercel): auth-hashes.json não é deployado.
# Use AUTH_HASHES_B64 (recomendado - evita corrupção): node scripts/print-auth-hashes-env.js
# AUTH_HASHES_B64=eyJhZG1pbiI6IiQyYiQxMCQ...

# NFe — consulta por chave na SEFAZ (certificado A1 por loja):
# Local: preencha .env.local (ex.: npm run nfe:env:ipanema com NFE_IPANEMA_PASSWORD).
# Produção (Vercel): .env.local NÃO sobe no deploy. Cadastre as MESMAS chaves em
#   Dashboard → Project → Settings → Environment Variables → Production
#   ou: npm run nfe:vercel:env  (lê .env.local e envia via CLI; depois Redeploy)
# node scripts/nfe-cert-to-base64.js "caminho/certificado.pfx"
# ipanema → certificado PROMESSA (somente este login usa estas variáveis)
# NFE_CERT_BASE64_IPANEMA=
# NFE_CERT_PASSWORD_IPANEMA=
# NFE_CNPJ_IPANEMA=04839192000185
# leblon → certificado PROVISAO (somente este login usa estas variáveis)
# NFE_CERT_BASE64_LEBLON=
# NFE_CERT_PASSWORD_LEBLON=
# NFE_CNPJ_LEBLON=
# NFE_AMBIENTE=1 (produção) ou 2 (homologação)

# Tickets Revisar Produto (tabela product_review_tickets):
# npm run db:migrate:product-review  (com DATABASE_URL) ou rode 014_product_review_tickets.sql no SQL Editor

# API Cosmos Bluesoft — base https://api.cosmos.bluesoft.com.br (documentação: https://cosmos.bluesoft.com.br/api)
# COSMOS_TOKEN=
# Conta varejista: use rotas /retailers/* (GET /retailers/gtins/{código}, /retailers/ncms/{código}, etc.)
# COSMOS_RETAILER_API=true

# Consulta fiscal (planilha no Supabase — opcional):
# 1) Rode supabase/migrations/013_create_fiscal_regras.sql no SQL Editor (ou: npm run db:migrate:fiscal com DATABASE_URL)
# 2) Importe dados: npm run seed:fiscal (requer SUPABASE_SERVICE_ROLE_KEY)

# Para migrações automáticas (opcional):
# Opção 1: Personal Access Token em https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxx
# Opção 2: Connection string em Project Settings > Database
# DATABASE_URL=postgresql://postgres.[ref]:[SENHA]@...
